# CodeDrop backend — environment (all optional)
# Copy to `.env` and edit, or just run with defaults and configure SMTP in the UI.

# Port the server listens on.
PORT=8787

# CORS: the origin your front-end is served from. Use "*" only for local dev.
# Example for a deployed front-end: CORS_ORIGIN=https://codes.example.com
CORS_ORIGIN=*

# --- Lock SMTP credentials to the server (recommended for shared deploys) ---
# When true, the server IGNORES the SMTP fields from the browser and uses the
# values below instead — so credentials never travel from the client at all.
SMTP_FROM_ENV=false

# Only used when SMTP_FROM_ENV=true:
SMTP_HOST=smtp.your-provider.com
SMTP_PORT=465
SMTP_SECURITY=SSL/TLS        # SSL/TLS or STARTTLS
SMTP_USER=you@your-provider.com
SMTP_PASS=your-app-password
SMTP_FROM_NAME=MakePaper
SMTP_FROM_EMAIL=you@your-provider.com
